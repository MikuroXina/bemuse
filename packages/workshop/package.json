{
  "name": "fresh-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "wireit",
    "typegen": "react-router typegen",
    "check": "wireit",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "wireit": {
    "build": {
      "command": "react-router build",
      "dependencies": [
        "../bemuse-types:build",
        "../bemuse-indexer:build",
        "../bemuse-notechart:build",
        "../bms:build",
        "typegen"
      ],
      "files": [
        "app/**/*",
        "vite.config.js",
        "public/**/*",
        "react-router.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "build/**"
      ]
    },
    "check": {
      "command": "eslint . && tsc",
      "dependencies": [
        "typegen"
      ],
      "files": [
        "app/**/*",
        "eslint.config.mjs",
        "react-router.config.ts",
        "tsconfig.json",
        "vite.config.js"
      ],
      "output": []
    }
  },
  "devDependencies": {
    "@mikuroxina/bemuse-types": "workspace:*",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@react-router/dev": "^7.13.1",
    "@types/chroma-js": "^3.0.0",
    "@types/lodash": "^4.14.175",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@types/wicg-file-system-access": "^2020.9.4",
    "@vitest/browser-playwright": "^4.0.18",
    "eslint": "^9.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mikuroxina/bemuse-indexer": "workspace:*",
    "@mikuroxina/bemuse-notechart": "workspace:*",
    "@mikuroxina/bms": "workspace:*",
    "@react-router/fs-routes": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@ui5/webcomponents": "^2.19.2",
    "@ui5/webcomponents-fiori": "^2.19.2",
    "@ui5/webcomponents-icons": "^2.19.2",
    "@ui5/webcomponents-react": "^2.19.0",
    "buffer": "^6.0.3",
    "chroma-js": "^3.0.0",
    "isbot": "^5.1.35",
    "lodash": "^4.17.21",
    "markdown-it": "^12.2.0",
    "md5.js": "^1.3.5",
    "memoize-one": "^6.0.0",
    "minimatch": "^10.2.4",
    "p-memoize": "4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.13.1",
    "spark-md5": "^3.0.2",
    "valibot": "^1.2.0"
  }
}
