{
  "name": "@mikuroxina/scoreboard-types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "wireit",
    "check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "wireit": {
    "build": {
      "command": "tsc",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist",
        "tsconfig.tsbuildinfo"
      ]
    }
  },
  "author": "MikuroXina <mikuroxina@gmail.com>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "eslint": "^9.0.0",
    "typescript": "^6.0.0",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "valibot": "^1.2.0"
  }
}
