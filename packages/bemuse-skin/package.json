{
  "name": "@mikuroxina/bemuse-skin",
  "version": "1.0.0",
  "description": "The build scripts for Bemuse's skin XML.",
  "type": "module",
  "files": [
    "dist/assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bemuse-skin.js",
      "require": "./dist/bemuse-skin.umd.cjs"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "build": "wireit",
    "dev": "wireit"
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*",
        "package.json",
        "vite.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "dev": {
      "command": "vite",
      "dependencies": [
        "build"
      ],
      "files": [
        "src/**/*",
        "package.json",
        "vite.config.ts",
        "tsconfig.json"
      ],
      "service": true
    }
  },
  "author": "MikuroXina <mikuroxina@gmail.com>",
  "license": "AGPL-1.0",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
