{
  "name": "@mikuroxina/bemuse-tools",
  "version": "52.0.0",
  "description": "bemuse-tools: Tools for Bemuse",
  "type": "module",
  "files": [
    "src",
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "wireit",
    "typecheck": "tsc -p .",
    "lint": "eslint ."
  },
  "wireit": {
    "build": {
      "command": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/main.js --banner:js='#!/usr/bin/env node' && chmod +x dist/main.js",
      "dependencies": [
        "../bemuse-indexer:build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json"
      ],
      "output": [
        "dist/main.js"
      ]
    }
  },
  "bin": {
    "bemuse-tools": "./dist/main.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bemusic/bemuse-tools.git"
  },
  "author": "Thai Pangsakulyanont <org.yi.dttvb@gmail.com> (http://dt.in.th/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bemusic/bemuse-tools/issues"
  },
  "homepage": "https://github.com/bemusic/bemuse-tools",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/middie": "^9.3.1",
    "@fastify/static": "^9.0.0",
    "@mikuroxina/bemuse-indexer": "workspace:*",
    "bytes": "^3.0.0",
    "chalk": "^5.6.2",
    "fastify": "^5.8.4",
    "glob": "^13.0.0",
    "js-yaml": "^3.12.0",
    "lodash": "^4.17.11",
    "meow": "^14.1.0",
    "spark-md5": "^3.0.2",
    "throat": "^6.0.2"
  },
  "devDependencies": {
    "@mikuroxina/bemuse-types": "workspace:*",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@types/bytes": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "24",
    "@types/spark-md5": "^3.0.5",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wireit": "^0.14.12"
  }
}
