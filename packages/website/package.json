{
  "name": "bemuse-docs",
  "version": "50.0.0",
  "private": true,
  "scripts": {
    "examples": "docusaurus-examples",
    "start": "docusaurus start",
    "build": "wireit",
    "publish-gh-pages": "docusaurus-publish",
    "write-translations": "docusaurus-write-translations",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "docusaurus": "docusaurus",
    "lint": "wireit"
  },
  "wireit": {
    "build": {
      "command": "docusaurus build",
      "files": [
        "docs/**/*",
        "i18n/**/*",
        "src/**/*",
        "static/**/*",
        "blog/**/*",
        "docusaurus.config.js",
        "sidebars.json",
        "tsconfig.json"
      ],
      "output": [
        ".docusaurus/**",
        "build/**"
      ]
    },
    "lint": {
      "command": "eslint .",
      "files": [
        "docs/**/*",
        "i18n/**/*",
        "src/**/*",
        "static/**/*",
        "blog/**/*",
        "docusaurus.config.js",
        "eslint.config.mjs",
        "sidebars.json",
        "tsconfig.json"
      ],
      "output": []
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.0",
    "@docusaurus/plugin-client-redirects": "^3.9.0",
    "@docusaurus/preset-classic": "^3.9.0",
    "@docusaurus/theme-classic": "^3.9.2",
    "@mdx-js/react": "^3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/eslint-plugin": "^3.9.2",
    "@docusaurus/module-type-aliases": "^3.9.0",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@tsconfig/docusaurus": "^2.0.9",
    "@types/node": "24",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "typescript": "^6.0.0",
    "wireit": "^0.14.12"
  }
}
