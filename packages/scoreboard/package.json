{
  "name": "@mikuroxina/bemuse-scoreboard",
  "version": "1.0.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "dev": "wireit",
    "deploy": "wireit"
  },
  "wireit": {
    "dev": {
      "command": "wrangler dev",
      "dependencies": [
        "../scoreboard-types:build"
      ]
    },
    "deploy": {
      "command": "wrangler deploy",
      "dependencies": [
        "../scoreboard-types:build"
      ]
    }
  },
  "author": "MikuroXina <mikuroxina@gmail.com>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@auth0/auth0-hono": "^1.2.6",
    "@hono/standard-validator": "^0.2.2",
    "@hono/valibot-validator": "^0.6.1",
    "@mikuroxina/scoreboard-types": "workspace:*",
    "auth0": "^5.5.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "valibot": "^1.2.0"
  }
}
