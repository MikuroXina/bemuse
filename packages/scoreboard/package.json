{
  "name": "@mikuroxina/bemuse-scoreboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "build": "wireit",
    "dev": "wireit",
    "deploy": "wireit",
    "use-test-data": "wrangler d1 execute score --local --file=test-data.sql",
    "test": "wireit"
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "dependencies": [
        "../scoreboard-types:build"
      ],
      "files": [
        "src/view.tsx",
        "src/view/**/*"
      ],
      "output": [
        "dist/**"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "dev": {
      "command": "vite dev",
      "service": true
    },
    "deploy": {
      "command": "wrangler deploy",
      "dependencies": [
        "build"
      ]
    },
    "test": {
      "command": "vitest run",
      "env": {
        "TEST": "true"
      },
      "dependencies": [
        "../scoreboard-types:build"
      ],
      "files": [
        "src/**"
      ]
    }
  },
  "author": "MikuroXina <mikuroxina@gmail.com>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.25.1",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.4",
    "wireit": "^0.14.12",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/valibot-validator": "^0.6.1",
    "@mikuroxina/scoreboard-types": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "auth0": "^5.5.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "temporal-polyfill": "^0.3.2",
    "valibot": "^1.2.0"
  }
}
