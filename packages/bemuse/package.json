{
  "name": "bemuse",
  "description": "BEAT☆MUSIC☆SEQUENCE, a web-based music game of the future",
  "private": true,
  "browserslist": [
    ">0.25%",
    "not ie 11",
    "not op_mini all"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "wireit",
    "start": "pnpx http-server -p 5173 dist",
    "dev": "vite dev",
    "typecheck": "tsc",
    "pre-deploy": "wireit",
    "test": "wireit",
    "coverage": "wireit",
    "lint": "eslint ."
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "dependencies": [
        "../bemuse-indexer:build",
        "../bemuse-notechart:build",
        "../bemuse-types:build",
        "../monetizer:build",
        "../bms:build",
        "../bmson:build"
      ]
    },
    "pre-deploy": {
      "command": "gulp pre-deploy",
      "dependencies": [
        "build",
        "../website:build",
        "../workshop:build"
      ]
    },
    "test": {
      "command": "vitest run",
      "env": {
        "NODE_ENV": "test",
        "BEMUSE_COV": ""
      },
      "dependencies": [
        "build"
      ]
    },
    "coverage": {
      "command": "vitest run --coverage",
      "env": {
        "NODE_ENV": "test",
        "BEMUSE_COV": "true"
      }
    }
  },
  "importSort": {
    ".js, .jsx, .es6, .es": {
      "parser": "babylon",
      "style": "renke"
    }
  },
  "author": "Thai Pangsakulyanont <dtinth@spacet.me> (http://dt.in.th/)",
  "license": "AGPL-1.0",
  "devDependencies": {
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@mikuroxina/monetizer": "workspace:*",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/debug": "^4.1.12",
    "@types/fastclick": "^1.0.33",
    "@types/gulp": "^4.0.18",
    "@types/invariant": "^2.2.37",
    "@types/jquery": "^3.5.33",
    "@types/lodash": "^4.17.23",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "24",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/webpack-env": "^1.18.8",
    "@types/wicg-file-system-access": "^2020.9.8",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "body-parser": "^1.20.4",
    "chalk": "^2.4.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "gulp": "^5.0.1",
    "js-yaml": "^3.14.2",
    "playwright": "^1.58.2",
    "pug": "^2.0.4",
    "puppeteer": "^24.37.0",
    "sass": "^1.97.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "~6.2.1",
    "@fortawesome/free-brands-svg-icons": "~6.2.1",
    "@fortawesome/free-regular-svg-icons": "~6.2.1",
    "@fortawesome/free-solid-svg-icons": "~6.2.1",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@mikuroxina/bemuse-indexer": "workspace:*",
    "@mikuroxina/bemuse-notechart": "workspace:*",
    "@mikuroxina/bemuse-types": "workspace:*",
    "@mikuroxina/bms": "workspace:*",
    "@mikuroxina/bmson": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@reduxjs/toolkit": "^1.9.7",
    "@tanstack/react-query": "^5.90.21",
    "bson-objectid": "^2.0.4",
    "bytes": "^3.1.2",
    "debug": "^3.2.7",
    "delay": "^5.0.0",
    "downshift": "~6.1.12",
    "fastclick": "^1.0.6",
    "fuzzysort": "~1.1.4",
    "idb-keyval": "^6.2.2",
    "immer": "~9.0.21",
    "immutable": "^4.3.7",
    "invariant": "^2.2.4",
    "jquery": "^3.7.1",
    "keycode": "^2.2.1",
    "keytime": "^0.1.1",
    "libarchive.js": "^1.3.0",
    "lodash": "^4.17.23",
    "markdown-it": "^13.0.2",
    "object-hash": "^3.0.0",
    "once": "^1.4.0",
    "p-map": "^4.0.0",
    "p-memoize": "^4.0.4",
    "pixi.js": "^8.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "reselect": "^4.1.8",
    "screenfull": "^6.0.2",
    "throat": "^2.0.2",
    "timesynchro": "^1.0.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,scss,css,yml}": [
      "prettier --write",
      "git add"
    ]
  }
}
