{
  "name": "bemuse",
  "description": "BEAT☆MUSIC☆SEQUENCE, a web-based music game of the future",
  "private": true,
  "browserslist": [
    ">0.25%",
    "not ie 11",
    "not op_mini all"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "wireit",
    "start": "pnpx http-server -p 5173 dist",
    "dev": "vite dev",
    "typecheck": "tsc",
    "pre-deploy": "wireit",
    "test": "wireit",
    "coverage": "wireit",
    "lint": "eslint .",
    "analyze": "wireit"
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "dependencies": [
        "../scoreboard-types:build",
        "../bemuse-indexer:build",
        "../bemuse-notechart:build",
        "../bemuse-types:build",
        "../bms:build",
        "../bmson:build"
      ],
      "files": [
        "public/**/*",
        "src/**/*",
        "types/**/*",
        ".env*",
        "index.html",
        "tsconfig.json",
        "vite.config.ts"
      ],
      "output": [
        "dist/**"
      ]
    },
    "pre-deploy": {
      "command": "gulp pre-deploy",
      "clean": false,
      "dependencies": [
        "build",
        "../website:build",
        "../workshop:build"
      ],
      "output": [
        "dist/**"
      ]
    },
    "test": {
      "command": "vitest run",
      "env": {
        "NODE_ENV": "test",
        "BEMUSE_COV": ""
      },
      "dependencies": [
        "build"
      ]
    },
    "coverage": {
      "command": "vitest run --coverage",
      "env": {
        "NODE_ENV": "test",
        "BEMUSE_COV": "true"
      }
    },
    "analyze": {
      "command": "vite build",
      "env": {
        "NODE_ENV": "production",
        "ANALYZE": "true"
      },
      "service": true
    }
  },
  "importSort": {
    ".js, .jsx, .es6, .es": {
      "parser": "babylon",
      "style": "renke"
    }
  },
  "author": "Thai Pangsakulyanont <dtinth@spacet.me> (http://dt.in.th/)",
  "license": "AGPL-1.0",
  "devDependencies": {
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/bytes": "^3.1.5",
    "@types/debug": "^4.1.12",
    "@types/fastclick": "^1.0.33",
    "@types/gulp": "^4.0.18",
    "@types/invariant": "^2.2.37",
    "@types/jquery": "^3.5.33",
    "@types/lodash": "^4.17.23",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "24",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.8",
    "@types/wicg-file-system-access": "^2020.9.8",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "chalk": "^2.4.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "gulp": "^5.0.1",
    "js-yaml": "^3.14.2",
    "playwright": "^1.59.1",
    "puppeteer": "^24.37.0",
    "sass": "^1.97.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-bundle-analyzer": "^1.3.7",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mikuroxina/bemuse-indexer": "workspace:*",
    "@mikuroxina/bemuse-notechart": "workspace:*",
    "@mikuroxina/bemuse-types": "workspace:*",
    "@mikuroxina/bms": "workspace:*",
    "@mikuroxina/bmson": "workspace:*",
    "@mikuroxina/scoreboard-types": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "bson-objectid": "^2.0.4",
    "bytes": "^3.1.2",
    "debug": "^3.2.7",
    "downshift": "~6.1.12",
    "fastclick": "^1.0.6",
    "fuzzysort": "~1.9.0",
    "idb-keyval": "^6.2.2",
    "immer": "~11.1.0",
    "immutable": "^4.3.7",
    "invariant": "^2.2.4",
    "jquery": "^3.7.1",
    "keycode": "^2.2.1",
    "keytime": "^0.1.1",
    "libarchive.js": "^1.3.0",
    "lodash": "^4.17.23",
    "markdown-it": "^13.0.2",
    "object-hash": "^3.0.0",
    "once": "^1.4.0",
    "p-map": "^4.0.0",
    "p-memoize": "^4.0.4",
    "pixi.js": "^8.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "redux": "^5.0.0",
    "reselect": "^4.1.8",
    "screenfull": "^6.0.2",
    "throat": "^2.0.2",
    "valibot": "^1.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,scss,css,yml}": [
      "prettier --write",
      "git add"
    ]
  }
}
