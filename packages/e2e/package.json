{
  "name": "bemuse-e2e",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.29.1",
    "eslint": "^10.0.0",
    "@mikuroxina/eslint-config-bemuse": "workspace:*",
    "typescript": "^6.0.0",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "http-server": "~14.1.1"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "wireit"
  },
  "wireit": {
    "test": {
      "command": "playwright test",
      "dependencies": [
        "../bemuse:pre-deploy"
      ],
      "files": [
        "tests/**/*",
        "eslint.config.mjs",
        "playwright.config.ts"
      ],
      "output": [
        "test-results/**"
      ]
    }
  }
}
